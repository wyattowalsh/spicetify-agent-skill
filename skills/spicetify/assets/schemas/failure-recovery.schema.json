{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/failure-recovery.schema.json",
  "title": "/spicetify Failure Recovery Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "severity",
    "detectionSignals",
    "stopPolicy",
    "safeRecovery",
    "verification",
    "rollback"
  ],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "detectionSignals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stopPolicy": {
      "type": "string",
      "enum": [
        "continue-readonly",
        "stop-before-mutation",
        "stop-before-fallback",
        "rollback-if-safe",
        "manual-only",
        "blocked"
      ]
    },
    "safeRecovery": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresConfirmation": {
      "type": "boolean",
      "default": false
    },
    "requiresSnapshot": {
      "type": "boolean",
      "default": false
    },
    "neverAutomate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
