{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/eval-result.schema.json",
  "title": "/spicetify Eval Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "suiteId",
    "startedAt",
    "completedAt",
    "gitSha",
    "runner",
    "summary",
    "caseResults",
    "artifacts"
  ],
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped",
        "error"
      ]
    }
  },
  "properties": {
    "runId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "suiteId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "startedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "completedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,64}$"
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "strict",
        "repeat"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "strict": {
          "type": "boolean"
        },
        "repeat": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "skipped",
        "errors",
        "blockingPassRate",
        "securityPassRate"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "blockingPassRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "securityPassRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "caseResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "caseId",
          "status",
          "score",
          "graderResults"
        ],
        "properties": {
          "caseId": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "mode": {
            "type": "string"
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/$defs/status"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "failureReason": {
            "type": "string"
          },
          "failures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "graderResults": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "status"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "status": {
                  "$ref": "#/$defs/status"
                },
                "notes": {
                  "type": "string"
                }
              }
            }
          },
          "artifacts": {
            "type": "object"
          },
          "repeats": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "json",
        "markdown",
        "traces"
      ],
      "properties": {
        "json": {
          "type": "string"
        },
        "markdown": {
          "type": "string"
        },
        "traces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
