{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/confirmation.schema.json",
  "title": "/spicetify Confirmation Grant",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "confirmationId",
    "planId",
    "planHash",
    "grants",
    "createdAt",
    "expiresAt",
    "humanSummaryAccepted",
    "driftPolicy"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "grant": {
      "type": "string",
      "enum": [
        "snapshot",
        "medium-mutation",
        "high-mutation",
        "destructive",
        "third-party-code",
        "network-fetch",
        "devtools-log",
        "screenshot",
        "launch-flag",
        "package-manager",
        "permission-change",
        "manual-only"
      ]
    }
  },
  "properties": {
    "confirmationId": {
      "type": "string",
      "pattern": "^conf_[A-Za-z0-9_-]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9_-]+$"
    },
    "planHash": {
      "$ref": "#/$defs/sha256"
    },
    "snapshotId": {
      "type": "string"
    },
    "grants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/grant"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "createdAt": {
      "$ref": "#/$defs/timestamp"
    },
    "expiresAt": {
      "$ref": "#/$defs/timestamp"
    },
    "humanSummaryAccepted": {
      "type": "boolean",
      "const": true
    },
    "acceptedRiskRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "driftPolicy": {
      "type": "string",
      "enum": [
        "invalidate-on-any-drift",
        "invalidate-on-source-drift",
        "manual-reconfirm"
      ]
    },
    "revokedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
