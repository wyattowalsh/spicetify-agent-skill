{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/eval-trace.schema.json",
  "title": "/spicetify Eval Trace",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceId",
    "caseId",
    "createdAt",
    "redacted",
    "skillActivation",
    "steps",
    "safety"
  ],
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "properties": {
    "traceId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "caseId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "createdAt": {
      "$ref": "#/$defs/timestamp"
    },
    "redacted": {
      "const": true
    },
    "skillActivation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activated",
        "evidence"
      ],
      "properties": {
        "activated": {
          "type": "boolean"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "skipped"
            ]
          },
          "mode": {
            "type": "string"
          },
          "policy": {
            "type": "string"
          },
          "commandIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "observation": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usedRealSpicetify",
        "touchedRealPaths",
        "ranShell",
        "usedNetwork",
        "leakedSecret"
      ],
      "properties": {
        "usedRealSpicetify": {
          "const": false
        },
        "touchedRealPaths": {
          "const": false
        },
        "ranShell": {
          "const": false
        },
        "usedNetwork": {
          "const": false
        },
        "leakedSecret": {
          "const": false
        }
      }
    }
  }
}
