{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/asset-analysis.schema.json",
  "title": "/spicetify Asset Analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportType",
    "status",
    "prompt",
    "route",
    "summary",
    "candidates",
    "safety",
    "degraded"
  ],
  "properties": {
    "reportType": { "const": "asset-analysis" },
    "status": { "enum": ["completed", "completed-degraded"] },
    "prompt": { "type": "string" },
    "route": { "$ref": "intent-route.schema.json" },
    "summary": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "assetKind",
          "source",
          "manifestStatus",
          "compatibilitySignals",
          "maintenanceSignals",
          "riskFindings",
          "provenanceReadiness",
          "confidence",
          "recommendedNextAction"
        ],
        "properties": {
          "assetKind": {
            "enum": ["theme", "extension", "custom-app", "snippet", "marketplace", "unknown"]
          },
          "source": { "$ref": "asset-source.schema.json" },
          "manifestStatus": { "type": "string" },
          "compatibilitySignals": { "type": "array", "items": { "type": "string" } },
          "maintenanceSignals": { "type": "array", "items": { "type": "string" } },
          "riskFindings": { "type": "array", "items": { "type": "string" } },
          "provenanceReadiness": { "type": "string" },
          "confidence": { "enum": ["low", "medium", "high"] },
          "recommendedNextAction": { "type": "string" }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trusted", "installAllowed", "reason"],
      "properties": {
        "trusted": { "const": false },
        "installAllowed": { "const": false },
        "reason": { "type": "string" }
      }
    },
    "degraded": { "type": "boolean" }
  }
}
