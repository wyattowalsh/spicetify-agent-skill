{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/operation-run.schema.json",
  "title": "/spicetify Operation Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runId",
    "planId",
    "startedAt",
    "status",
    "stepResults"
  ],
  "properties": {
    "runId": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9_-]+$"
    },
    "snapshotId": {
      "type": "string"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "not_started",
        "running",
        "verified",
        "failed",
        "rolled_back",
        "stopped"
      ]
    },
    "stepResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stepId",
          "status"
        ],
        "properties": {
          "stepId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pending",
              "running",
              "passed",
              "failed",
              "skipped"
            ]
          },
          "commandId": {
            "type": "string"
          },
          "stdoutRedacted": {
            "type": "string"
          },
          "stderrRedacted": {
            "type": "string"
          },
          "errorCode": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "$ref": "verification-report.schema.json"
    },
    "rollbackAttempt": {
      "type": "object",
      "additionalProperties": true
    },
    "confirmationId": {
      "type": "string",
      "pattern": "^conf_[A-Za-z0-9_-]+$"
    },
    "planHashAtExecution": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "driftResult": {
      "type": "string",
      "enum": [
        "not-checked",
        "matched",
        "drifted-invalidated",
        "manual-reconfirm-required"
      ]
    }
  }
}
