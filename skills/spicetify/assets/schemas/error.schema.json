{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/error.schema.json",
  "title": "/spicetify Error",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code",
    "severity",
    "message",
    "safeNextActions",
    "requiresUserDecision"
  ],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "message": {
      "type": "string"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "safeNextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiresUserDecision": {
      "type": "boolean"
    },
    "stop": {
      "type": "boolean",
      "default": false
    }
  }
}
