{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/provenance-lock.schema.json",
  "title": "/spicetify Provenance Lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "generatedAt",
    "entries"
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inspect",
        "doctor",
        "snapshot",
        "restore",
        "repair",
        "apply",
        "config",
        "profile",
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace",
        "audit",
        "devtools",
        "watch",
        "migrate",
        "update",
        "rollback",
        "uninstall",
        "report"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "low",
        "medium",
        "high",
        "blocked"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\x00)"
      }
    },
    "approvalGate": {
      "type": "string",
      "enum": [
        "none",
        "snapshot",
        "confirm",
        "separate-confirm",
        "manual-only",
        "blocked"
      ]
    },
    "findingSeverity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  },
  "properties": {
    "schema": {
      "const": "spicetify.provenance-lock"
    },
    "generatedAt": {
      "$ref": "#/$defs/timestamp"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "assetType",
          "trustLevel",
          "sourceKind",
          "installedPath",
          "contentHash",
          "auditVerdict"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "assetType": {
            "enum": [
              "theme",
              "extension",
              "custom-app",
              "snippet",
              "marketplace",
              "generated"
            ]
          },
          "trustLevel": {
            "enum": [
              "generated-local",
              "trusted-local",
              "third-party-staged",
              "marketplace",
              "unknown"
            ]
          },
          "sourceKind": {
            "enum": [
              "generated",
              "local-path",
              "github",
              "archive",
              "inline",
              "marketplace"
            ]
          },
          "sourceUrl": {
            "type": "string"
          },
          "ref": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "installedPath": {
            "$ref": "#/$defs/safeRelativePath"
          },
          "contentHash": {
            "$ref": "#/$defs/sha256"
          },
          "manifestHash": {
            "$ref": "#/$defs/sha256"
          },
          "auditId": {
            "type": "string"
          },
          "auditVerdict": {
            "enum": [
              "allow",
              "warn",
              "block",
              "not-audited"
            ]
          },
          "acceptedRisks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptedAt": {
            "$ref": "#/$defs/timestamp"
          }
        }
      }
    }
  }
}
