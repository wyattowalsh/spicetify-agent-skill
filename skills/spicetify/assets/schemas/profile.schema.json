{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/profile.schema.json",
  "title": "/spicetify Profile Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "config",
    "extensions",
    "customApps",
    "snippets",
    "safety",
    "verification"
  ],
  "properties": {
    "schema": {
      "const": "spicetify.profile"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string"
    },
    "inherits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spicetify": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "enum": [
              "win32",
              "darwin",
              "linux"
            ]
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "current_theme": {
          "type": "string"
        },
        "color_scheme": {
          "type": "string"
        },
        "additionalOptions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+\\.js$"
          }
        },
        "provenanceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "customApps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._-]+$"
          }
        },
        "provenanceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "snippets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "provenanceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowThirdPartyJs",
        "allowLaunchFlags",
        "requireSnapshot"
      ],
      "properties": {
        "allowThirdPartyJs": {
          "type": "boolean"
        },
        "allowLaunchFlags": {
          "type": "boolean"
        },
        "requireSnapshot": {
          "type": "boolean"
        },
        "maxRisk": {
          "enum": [
            "read",
            "low",
            "medium",
            "high",
            "blocked"
          ]
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "enum": [
          "configMatchesProfile",
          "filesExist",
          "spicetifyApplySuccess",
          "doctorNoHighFindings",
          "auditAccepted"
        ]
      }
    }
  }
}
