{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/docs-page.schema.json",
  "title": "Docs Page",
  "type": "object",
  "required": ["title", "description", "section", "source", "sourcePath", "status", "safetyLevel"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "section": { "type": "string", "enum": ["overview", "concepts", "modes", "workflows", "security", "reference", "development", "docs-site"] },
    "source": { "type": "string", "enum": ["curated", "generated"] },
    "sourcePath": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "default": "docs" },
    "status": { "type": "string", "enum": ["proposed", "reviewed", "generated"] },
    "safetyLevel": { "type": "string", "enum": ["read", "low", "medium", "high"] },
    "links": { "type": "array", "items": { "type": "string" }, "default": [] },
    "generated": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generator": { "type": "string" },
        "sourceHash": { "type": "string" },
        "redacted": { "type": "boolean", "default": true }
      }
    }
  }
}
