{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/policy-decision.schema.json",
  "title": "/spicetify Policy Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionId",
    "planId",
    "risk",
    "approvalGate",
    "allowed",
    "reasons"
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inspect",
        "doctor",
        "snapshot",
        "restore",
        "repair",
        "apply",
        "config",
        "profile",
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace",
        "audit",
        "devtools",
        "watch",
        "migrate",
        "update",
        "rollback",
        "uninstall",
        "report"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "low",
        "medium",
        "high",
        "blocked"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\x00)"
      }
    },
    "approvalGate": {
      "type": "string",
      "enum": [
        "none",
        "snapshot",
        "confirm",
        "separate-confirm",
        "manual-only",
        "blocked"
      ]
    },
    "findingSeverity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  },
  "properties": {
    "decisionId": {
      "type": "string",
      "pattern": "^pdec_[A-Za-z0-9_-]+$"
    },
    "planId": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9_-]+$"
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "approvalGate": {
      "$ref": "#/$defs/approvalGate"
    },
    "allowed": {
      "type": "boolean"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "requiredConfirmations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockedActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptedRiskRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
