{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/redaction-policy.schema.json",
  "title": "/spicetify Redaction Policy",
  "type": "object",
  "required": [
    "policyId",
    "shareability",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "policyId": {
      "type": "string"
    },
    "shareability": {
      "type": "string",
      "enum": [
        "local-only",
        "redacted-shareable",
        "strict-shareable"
      ]
    },
    "maskPaths": {
      "type": "boolean",
      "default": false
    },
    "maskUsernames": {
      "type": "boolean",
      "default": true
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "action"
        ],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "token",
              "cookie",
              "authorization-header",
              "credential-flag",
              "private-path",
              "prefs-content",
              "unknown-sensitive"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "mask",
              "omit",
              "block-share"
            ]
          },
          "marker": {
            "type": "string"
          }
        }
      }
    },
    "finalSecretScan": {
      "type": "boolean",
      "const": true
    }
  }
}
