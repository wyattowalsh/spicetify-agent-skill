{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/operation-plan.schema.json",
  "title": "/spicetify Operation Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "createdAt",
    "mode",
    "title",
    "dryRun",
    "risk",
    "requiresSnapshot",
    "requiresConfirmation",
    "preconditions",
    "mutations",
    "commands",
    "verifications",
    "rollback",
    "policyDecision",
    "planHash"
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inspect",
        "doctor",
        "snapshot",
        "restore",
        "repair",
        "apply",
        "config",
        "profile",
        "manifest",
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace",
        "audit",
        "devtools",
        "watch",
        "migrate",
        "update",
        "rollback",
        "uninstall",
        "report"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "low",
        "medium",
        "high",
        "blocked"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\x00)"
      }
    },
    "approvalGate": {
      "type": "string",
      "enum": [
        "none",
        "snapshot",
        "confirm",
        "separate-confirm",
        "manual-only",
        "blocked"
      ]
    },
    "findingSeverity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "mutation": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type",
            "path"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "mkdir"
            },
            "path": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "owner": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "sha256After",
            "backup"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "writeFile"
            },
            "path": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "sha256Before": {
              "$ref": "#/$defs/sha256"
            },
            "sha256After": {
              "$ref": "#/$defs/sha256"
            },
            "backup": {
              "type": "boolean"
            },
            "owner": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "from",
            "to",
            "sha256After",
            "backup"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "copyFile"
            },
            "from": {
              "type": "string"
            },
            "to": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "sha256After": {
              "$ref": "#/$defs/sha256"
            },
            "backup": {
              "type": "boolean"
            },
            "owner": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "path",
            "requiresConfirmation"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "deleteFile"
            },
            "path": {
              "$ref": "#/$defs/safeRelativePath"
            },
            "requiresConfirmation": {
              "const": true
            },
            "owner": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "key",
            "before",
            "after"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "const": "configSet"
            },
            "key": {
              "type": "string"
            },
            "before": {},
            "after": {},
            "strategy": {
              "enum": [
                "cli",
                "transactional-ini"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "key",
            "value"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "enum": [
                "configListAdd",
                "configListRemove"
              ]
            },
            "key": {
              "enum": [
                "extensions",
                "custom_apps"
              ]
            },
            "value": {
              "type": "string"
            },
            "strategy": {
              "enum": [
                "cli",
                "transactional-ini"
              ]
            }
          }
        }
      ]
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "cli-output",
            "config",
            "filesystem",
            "snapshot",
            "audit",
            "devtools-log",
            "screenshot",
            "doctor",
            "schema"
          ]
        },
        "expected": {},
        "required": {
          "type": "boolean",
          "default": true
        },
        "redaction": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "required"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "failureCode": {
          "type": "string"
        }
      }
    }
  },
  "properties": {
    "planId": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9_-]+$"
    },
    "createdAt": {
      "$ref": "#/$defs/timestamp"
    },
    "mode": {
      "$ref": "#/$defs/mode"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "dryRun": {
      "const": true
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "requiresSnapshot": {
      "type": "boolean"
    },
    "requiresConfirmation": {
      "type": "boolean"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/precondition"
      }
    },
    "mutations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mutation"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "command-invocation.schema.json"
      }
    },
    "verifications": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification"
      }
    },
    "rollback": {
      "type": "object",
      "required": [
        "strategy",
        "snapshotRequired"
      ],
      "additionalProperties": true,
      "properties": {
        "strategy": {
          "enum": [
            "none",
            "restore-snapshot",
            "inverse-mutations",
            "spicetify-restore",
            "manual"
          ]
        },
        "snapshotRequired": {
          "type": "boolean"
        }
      }
    },
    "auditRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenanceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policyDecision": {
      "$ref": "policy-decision.schema.json"
    },
    "idempotencyKey": {
      "type": "string"
    },
    "driftChecks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "planHash": {
      "$ref": "#/$defs/sha256"
    },
    "confirmationContract": {
      "$ref": "confirmation.schema.json",
      "description": "Optional confirmation grant required when the policy decision requires human approval. The grant is valid only for this plan hash."
    }
  }
}
