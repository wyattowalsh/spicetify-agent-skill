{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/audit-report.schema.json",
  "title": "/spicetify Audit Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auditId",
    "createdAt",
    "target",
    "verdict",
    "installAllowedByDefault",
    "findings",
    "provenance"
  ],
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "code",
        "message",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "severity": {
          "enum": [
            "info",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "recommendation": {
          "type": "string"
        },
        "blocksInstall": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    }
  },
  "properties": {
    "auditId": {
      "type": "string",
      "pattern": "^audit_[A-Za-z0-9_-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "sourceKind"
      ],
      "properties": {
        "type": {
          "enum": [
            "theme",
            "extension",
            "custom-app",
            "snippet",
            "marketplace-repo",
            "repo",
            "archive"
          ]
        },
        "name": {
          "type": "string"
        },
        "sourceKind": {
          "enum": [
            "local",
            "staged-download",
            "inline",
            "generated"
          ]
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "verdict": {
      "enum": [
        "allow",
        "warn",
        "block"
      ]
    },
    "installAllowedByDefault": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "compatibilityFindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "promptInjectionFindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        },
        "manifest": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "lockEntryId": {
          "type": "string"
        }
      }
    }
  }
}
