{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/asset-manifest.schema.json",
  "title": "/spicetify Asset Manifest",
  "type": "object",
  "required": [
    "assetId",
    "kind",
    "trust",
    "ownership",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "assetId": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": [
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace-item",
        "profile",
        "config"
      ]
    },
    "trust": {
      "type": "string",
      "enum": [
        "generated",
        "local-trusted",
        "third-party",
        "marketplace",
        "built-in",
        "unknown"
      ]
    },
    "ownership": {
      "type": "string",
      "enum": [
        "skill-owned",
        "user-owned",
        "package-owned",
        "unknown"
      ]
    },
    "sourceId": {
      "type": "string"
    },
    "auditId": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "role": {
            "type": "string"
          }
        }
      }
    },
    "installState": {
      "type": "string",
      "enum": [
        "staged",
        "installed",
        "enabled",
        "disabled",
        "removed"
      ],
      "default": "staged"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
