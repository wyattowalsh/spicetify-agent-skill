{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/command-registry-entry.schema.json",
  "title": "Spicetify Command Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verb",
    "executable",
    "argsTemplate",
    "risk",
    "requiresSnapshot",
    "requiresConfirmation",
    "timeoutMs",
    "outputParser",
    "argValidators"
  ],
  "properties": {
    "verb": {
      "type": "string",
      "enum": [
        "cliIdentity",
        "initOrVerify",
        "backup",
        "apply",
        "restore",
        "updateHotReload",
        "upgradeCli",
        "configView",
        "configGet",
        "configSet",
        "configListAppend",
        "configListRemove",
        "configDir",
        "configPath",
        "path",
        "pathUserdata",
        "pathSpotify",
        "enableDevTools",
        "watch",
        "auto"
      ]
    },
    "executable": {
      "const": "spicetify"
    },
    "argsTemplate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "lowMutation",
        "mediumMutation",
        "highMutation"
      ]
    },
    "requiresSnapshot": {
      "type": "boolean"
    },
    "requiresConfirmation": {
      "type": "boolean"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 300000
    },
    "allowedPlatforms": {
      "type": "array",
      "items": {
        "enum": [
          "win32",
          "darwin",
          "linux"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "outputParser": {
      "type": "string",
      "enum": [
        "text",
        "cliIdentity",
        "path",
        "config",
        "json",
        "none"
      ]
    },
    "argValidators": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "none",
          "safeConfigKey",
          "safeConfigValue",
          "safeExtensionFile",
          "safeCustomAppName",
          "safeThemeName",
          "safeBoolean",
          "safePathFromDiscovery",
          "noShellMetacharacters"
        ]
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
