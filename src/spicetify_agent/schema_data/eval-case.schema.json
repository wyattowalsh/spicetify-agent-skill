{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/eval-case.schema.json",
  "title": "/spicetify Eval Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "prompt",
    "category",
    "mode",
    "activation",
    "fixture",
    "expected",
    "forbid",
    "traceOracle",
    "text",
    "oracles",
    "rationale",
    "source"
  ],
  "allOf": [
    {
      "if": {
        "required": [
          "expected"
        ],
        "properties": {
          "expected": {
            "required": [
              "trace"
            ],
            "properties": {
              "trace": {
                "contains": {
                  "const": "fake-execute"
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "expected": {
            "required": [
              "executeFake"
            ],
            "properties": {
              "executeFake": {
                "const": true
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inspect",
        "doctor",
        "snapshot",
        "restore",
        "repair",
        "apply",
        "config",
        "profile",
        "manifest",
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace",
        "audit",
        "devtools",
        "watch",
        "migrate",
        "update",
        "rollback",
        "uninstall",
        "report",
        "evolve"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "mode-routing",
        "read-only",
        "mutation-workflow",
        "state-recovery",
        "configuration",
        "customization",
        "third-party",
        "security",
        "privacy",
        "installability",
        "evolution"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "low",
        "medium",
        "high",
        "blocked"
      ]
    },
    "policyDecision": {
      "type": "string",
      "enum": [
        "allowed",
        "dry-run-only",
        "confirmation-required",
        "manual-only",
        "blocked"
      ]
    },
    "traceStep": {
      "type": "string",
      "enum": [
        "activate-skill",
        "route-mode",
        "inspect-fixture",
        "audit-source",
        "policy-decision",
        "dry-run-plan",
        "snapshot-gate",
        "confirmation-gate",
        "fake-execute",
        "verify",
        "report",
        "rollback-metadata",
        "refuse",
        "redact",
        "evolve-review"
      ]
    },
    "oracle": {
      "type": "string",
      "enum": [
        "hard-safety",
        "structured-behavior",
        "fake-state",
        "trace",
        "text",
        "redaction",
        "human-review"
      ]
    },
    "activationKind": {
      "type": "string",
      "enum": [
        "direct-mode",
        "route-mode",
        "negative-trigger"
      ]
    },
    "traceMatch": {
      "type": "string",
      "enum": [
        "exact",
        "contains-in-order",
        "unordered-subset",
        "forbidden"
      ]
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "$ref": "#/$defs/category"
    },
    "mode": {
      "$ref": "#/$defs/mode"
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/activationKind"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "fixture": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "riskCategory": {
      "$ref": "#/$defs/risk"
    },
    "attackSurface": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "prompt",
          "readme",
          "marketplace-metadata",
          "third-party-code",
          "filesystem",
          "spicetify-cli",
          "devtools",
          "report",
          "eval-trace",
          "package-manager",
          "network"
        ]
      },
      "uniqueItems": true
    },
    "sourceTrust": {
      "type": "string",
      "enum": [
        "trusted-local-contract",
        "user-request",
        "untrusted-repo",
        "untrusted-marketplace",
        "untrusted-tool-output",
        "redacted-local-evidence"
      ]
    },
    "humanReviewRequired": {
      "type": "boolean"
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skillActivated",
        "mode",
        "policy",
        "risk",
        "mutates",
        "requiresSnapshot",
        "requiresConfirmation",
        "commandIds",
        "trace",
        "reportSchemas"
      ],
      "properties": {
        "skillActivated": {
          "type": "boolean"
        },
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "policy": {
          "$ref": "#/$defs/policyDecision"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "mutates": {
          "type": "boolean"
        },
        "requiresSnapshot": {
          "type": "boolean"
        },
        "requiresConfirmation": {
          "type": "boolean"
        },
        "commandIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          }
        },
        "trace": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/traceStep"
          },
          "minItems": 1
        },
        "reportSchemas": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "operation-plan",
              "operation-run",
              "operation-report",
              "audit-report",
              "snapshot-manifest",
              "verification-report",
              "evolution-report"
            ]
          }
        },
        "executeFake": {
          "type": "boolean"
        },
        "outputArtifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "dry-run-plan",
              "redacted-report",
              "snapshot-manifest",
              "provenance-lock",
              "rollback-metadata",
              "evolution-report"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "forbid": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "realPaths",
        "realSpicetifyBinary",
        "arbitraryShell",
        "network",
        "packageManager",
        "installerScripts",
        "secretsInOutput",
        "unapprovedMutation",
        "hostedEvalProvider",
        "commandIds"
      ],
      "properties": {
        "realPaths": {
          "const": true
        },
        "realSpicetifyBinary": {
          "const": true
        },
        "arbitraryShell": {
          "const": true
        },
        "network": {
          "const": true
        },
        "packageManager": {
          "const": true
        },
        "installerScripts": {
          "const": true
        },
        "secretsInOutput": {
          "const": true
        },
        "unapprovedMutation": {
          "const": true
        },
        "hostedEvalProvider": {
          "const": true
        },
        "commandIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        }
      }
    },
    "text": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mustInclude",
        "mustNotInclude"
      ],
      "properties": {
        "mustInclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "mustNotInclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "oracles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/oracle"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "stateOracle": {
      "type": "string",
      "enum": [
        "none",
        "no-mutation",
        "hash-manifest",
        "restore-exact",
        "plan-hash-drift",
        "fake-fs-diff",
        "rollback-exact",
        "redaction-corpus",
        "evolution-report"
      ]
    },
    "traceOracle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "match",
        "steps"
      ],
      "properties": {
        "match": {
          "$ref": "#/$defs/traceMatch"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/traceStep"
          }
        },
        "forbiddenSteps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/traceStep"
          },
          "uniqueItems": true
        },
        "allowExtra": {
          "type": "boolean"
        }
      }
    },
    "redactionOracle": {
      "type": "string",
      "enum": [
        "none",
        "secret-corpus",
        "private-paths",
        "devtools-logs",
        "all-artifacts"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "openspec",
            "planning-doc",
            "skill-reference",
            "regression-prompt",
            "research-derived"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
