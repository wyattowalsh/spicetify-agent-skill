{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/snapshot-manifest.schema.json",
  "title": "/spicetify Snapshot Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotId",
    "createdAt",
    "label",
    "platform",
    "scope",
    "sources",
    "excluded",
    "redaction"
  ],
  "$defs": {
    "mode": {
      "type": "string",
      "enum": [
        "inspect",
        "doctor",
        "snapshot",
        "restore",
        "repair",
        "apply",
        "config",
        "profile",
        "theme",
        "extension",
        "custom-app",
        "snippet",
        "marketplace",
        "audit",
        "devtools",
        "watch",
        "migrate",
        "update",
        "rollback",
        "uninstall",
        "report"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "read",
        "low",
        "medium",
        "high",
        "blocked"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "safeRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|\\x00)"
      }
    },
    "approvalGate": {
      "type": "string",
      "enum": [
        "none",
        "snapshot",
        "confirm",
        "separate-confirm",
        "manual-only",
        "blocked"
      ]
    },
    "findingSeverity": {
      "type": "string",
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  },
  "properties": {
    "snapshotId": {
      "type": "string",
      "pattern": "^snap_[A-Za-z0-9_-]+$"
    },
    "createdAt": {
      "$ref": "#/$defs/timestamp"
    },
    "label": {
      "type": "string"
    },
    "platform": {
      "enum": [
        "win32",
        "darwin",
        "linux"
      ]
    },
    "scope": {
      "type": "array",
      "items": {
        "enum": [
          "config",
          "themes",
          "extensions",
          "customApps",
          "snippets",
          "marketplace",
          "metadata"
        ]
      },
      "minItems": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "snapshotPath",
          "sha256"
        ],
        "properties": {
          "kind": {
            "enum": [
              "file",
              "directory",
              "metadata"
            ]
          },
          "path": {
            "type": "string"
          },
          "snapshotPath": {
            "$ref": "#/$defs/safeRelativePath"
          },
          "sha256": {
            "$ref": "#/$defs/sha256"
          },
          "owner": {
            "type": "string"
          }
        }
      }
    },
    "excluded": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokensMasked",
        "prefsContentCaptured"
      ],
      "properties": {
        "tokensMasked": {
          "type": "integer",
          "minimum": 0
        },
        "prefsContentCaptured": {
          "const": false
        },
        "absolutePathsMaskedInReport": {
          "type": "boolean"
        }
      }
    },
    "spicetifyCliIdentity": {
      "type": "string",
      "description": "Detected Spicetify CLI identity/identity string from local read-only discovery; never hardcoded as a compatibility guarantee."
    },
    "spotifyClientBuild": {
      "type": "string",
      "description": "Detected Spotify client build string when available; used for repair diagnostics only."
    }
  }
}
