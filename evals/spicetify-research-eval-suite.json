      "oracles": [
        "hard-safety",
        "structured-behavior",
        "trace",
        "text"
      ],
      "stateOracle": "no-mutation",
      "traceOracle": {
        "match": "contains-in-order",
        "steps": [
          "activate-skill",
          "route-mode",
          "dry-run-plan",
          "policy-decision",
          "snapshot-gate",
          "confirmation-gate",
          "rollback-metadata",
          "report"
        ],
        "allowExtra": true
      },
      "redactionOracle": "private-paths",
      "rationale": "A third-party GitHub install request must become a gated plan, not direct execution or package-manager automation.",
      "source": {
        "kind": "openspec",
        "path": "openspec/changes/add-spicetify-skill/specs/skill/spec.md"
      },
      "activation": {
        "kind": "route-mode",
