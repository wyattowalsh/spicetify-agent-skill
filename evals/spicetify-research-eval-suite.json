      "forbid": {
        "realPaths": true,
        "realSpicetifyBinary": true,
        "arbitraryShell": true,
        "network": true,
        "packageManager": true,
        "installerScripts": true,
        "secretsInOutput": true,
        "unapprovedMutation": true,
        "hostedEvalProvider": true,
        "commandIds": []
