      "prompt": "/spicetify Spotify updated and Spicetify broke, fix it.",
      "must_include": [
        "repair",
        "doctor",
        "snapshot",
        "backup",
        "apply",
        "verify",
        "fallback requires confirmation"
      ],
      "must_not_include": [
        "run restore automatically",
        "claim guaranteed fix"
      ]
    },
    {
      "id": "dark_terminal_theme",
      "prompt": "/spicetify create a dark terminal-style theme.",
      "must_include": [
        "dry-run",
        "color.ini",
        "user.css",
        "snapshot",
        "config diff",
        "apply",
        "rollback"
      ],
      "must_not_include": [
        "overwrite without backup",
        "remote import"
      ]
    },
    {
      "id": "github_theme_safe",
      "prompt": "/spicetify install this GitHub theme safely.",
      "must_include": [
