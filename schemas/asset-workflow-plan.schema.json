{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/asset-workflow-plan.schema.json",
  "title": "/spicetify Asset Workflow Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planType",
    "assetKind",
    "stateMachine",
    "steps",
    "containsShell",
    "executesPackageManager",
    "trusted"
  ],
  "properties": {
    "planType": { "const": "asset-workflow-plan" },
    "assetKind": {
      "enum": ["theme", "extension", "custom-app", "snippet", "marketplace", "unknown"]
    },
    "stateMachine": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "audited" }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assetKind", "status", "manualOnly"],
        "properties": {
          "id": { "type": "string" },
          "assetKind": {
            "enum": ["theme", "extension", "custom-app", "snippet", "marketplace", "unknown"]
          },
          "status": { "enum": ["planned", "blocked", "manual-only"] },
          "manualOnly": { "type": "boolean" }
        }
      }
    },
    "containsShell": { "const": false },
    "executesPackageManager": { "const": false },
    "trusted": { "const": false }
  }
}
