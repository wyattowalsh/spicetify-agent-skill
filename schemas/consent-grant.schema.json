{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/spicetify/consent-grant.schema.json",
  "title": "/spicetify Consent Grant",
  "type": "object",
  "required": [
    "consentId",
    "scope",
    "approvedEvidence",
    "redactionPolicy",
    "expiresAt"
  ],
  "additionalProperties": false,
  "properties": {
    "consentId": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": [
        "devtools-logs",
        "screenshot",
        "launch-flags",
        "config-excerpt",
        "source-archive",
        "network-staging",
        "build-script"
      ]
    },
    "approvedEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "durationSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "maxBytes": {
      "type": "integer",
      "minimum": 1
    },
    "redactionPolicy": {
      "type": "string"
    },
    "mayWriteToDisk": {
      "type": "boolean",
      "default": false
    },
    "mayIncludeInShareableReport": {
      "type": "boolean",
      "default": false
    },
    "expiresAt": {
      "type": "string"
    },
    "boundPlanHash": {
      "type": "string"
    }
  }
}
