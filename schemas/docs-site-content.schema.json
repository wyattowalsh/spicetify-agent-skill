{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Docs Site Content Map",
  "type": "object",
  "required": [
    "sections",
    "modePages",
    "workflowPages",
    "schemaPages"
  ],
  "additionalProperties": false,
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "title",
          "pages"
        ],
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "pages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "modePages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 22
    },
    "workflowPages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schemaPages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "syntheticExamplesOnly": {
          "type": "boolean",
          "const": true
        },
        "noPrefsContent": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
